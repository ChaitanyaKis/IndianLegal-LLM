# IndianLegal-LLM configuration (copy to .env; .env is gitignored).
# The walking skeleton runs with ALL of these unset — defaults are stdlib stubs.

# Base model id. MUST be a CONFIRMED Apache-2.0 or MIT model, verified against its
# current Hugging Face model card before use (CLAUDE.md §2).
#   microsoft/phi-4  -> MIT (default)
#   Gemma 4          -> Apache-2.0 as of its April 2026 release; confirm the exact
#                       repo id + size on the model card before use (Gemma 3 and
#                       earlier use Google's custom Gemma Terms and do NOT qualify).
BASE_MODEL=microsoft/phi-4

# Embedding backend id. Skeleton default is the stdlib token-overlap stub.
EMBEDDING_MODEL=stub-token-overlap

# Vector/retrieval backend. Skeleton default is the in-memory lexical retriever.
VECTOR_BACKEND=memory

# Number of chunks to retrieve per query.
TOP_K=3

# Ingestion source for build_pipeline(). Default is the real AWS Supreme Court
# dataset; the offline skeleton uses INGESTOR=stub. Real sources need the
# ingestion extra (pip install -e .[ingestion]); if unavailable, build_pipeline()
# transparently falls back to the stub so the skeleton always runs.
#   stub | aws-sc | aws-hc | india-code | indian-kanoon
INGESTOR=aws-sc

# Max documents pulled from a real source (the ingestion --limit).
INGEST_LIMIT=200

# Where the ingestion manifest is written (under the gitignored data/).
SOURCE_MANIFEST=data/source_manifest.jsonl

# Strict ingestion. When 1/true, a missing [ingestion] extra / network /
# credential is a HARD error instead of falling back to the stub. Default off
# (graceful fallback with a stderr warning). The ingestion CLI also takes
# --strict / --no-strict, which overrides this.
INGESTOR_STRICT=0

# LLM backend for build_pipeline(). Default "transformers" serves BASE_MODEL 4-bit
# on a CUDA GPU (needs the model extra: pip install -e .[model]). With no GPU /
# extra, build_pipeline() falls back to the offline "stub" (weights are NEVER
# downloaded on a CPU/laptop, CLAUDE.md §5). Use LLM=stub to force the stub.
#   transformers | stub
LLM=transformers
